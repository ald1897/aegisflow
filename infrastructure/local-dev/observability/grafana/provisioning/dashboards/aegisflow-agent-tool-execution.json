{
  "uid": "aegisflow-agent-tool-execution",
  "title": "AegisFlow - Agent And Tool Execution",
  "tags": ["aegisflow", "phase-6", "agents", "tools"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Agent Executions",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_agent_runtime_agent_executions_total[$__range]))",
          "legendFormat": "agent-runtime"
        },
        {
          "refId": "B",
          "expr": "sum(increase(aegisflow_workflow_engine_agent_executions_total[$__range]))",
          "legendFormat": "workflow-engine"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tool Invocations",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_tool_runtime_tool_invocations_total[$__range]))",
          "legendFormat": "tool-runtime"
        },
        {
          "refId": "B",
          "expr": "sum(increase(aegisflow_workflow_engine_tool_invocations_total[$__range]))",
          "legendFormat": "workflow-engine"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Authorization Failures",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_tool_runtime_tool_invocations_total{permission_status=\"DENIED\"}[$__range]))",
          "legendFormat": "denied"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Validation Failures",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_agent_runtime_agent_executions_total{validation_status=\"REJECTED\"}[$__range])) + sum(increase(aegisflow_tool_runtime_tool_invocations_total{input_validation_status=\"REJECTED\"}[$__range])) + sum(increase(aegisflow_tool_runtime_tool_invocations_total{output_validation_status=\"REJECTED\"}[$__range]))",
          "legendFormat": "validation failures"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Agent Execution Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent_id, status, validation_status) (rate(aegisflow_agent_runtime_agent_executions_total[$__rate_interval]))",
          "legendFormat": "{{agent_id}} {{status}} {{validation_status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Agent Execution Latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, agent_id) (rate(aegisflow_agent_runtime_agent_execution_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tool Invocation Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool_id, status, permission_status) (rate(aegisflow_tool_runtime_tool_invocations_total[$__rate_interval]))",
          "legendFormat": "{{tool_id}} {{status}} {{permission_status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tool Invocation Latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, tool_id) (rate(aegisflow_tool_runtime_tool_invocation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{tool_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Agent Graph Step Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent_id, step, status) (rate(aegisflow_agent_runtime_graph_steps_total[$__rate_interval]))",
          "legendFormat": "{{agent_id}} {{step}} {{status}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Mock Tool Handler Latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, tool_id) (rate(aegisflow_tool_runtime_handler_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{tool_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    }
  ]
}
