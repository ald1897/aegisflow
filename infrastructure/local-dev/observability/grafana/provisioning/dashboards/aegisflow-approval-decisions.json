{
  "uid": "aegisflow-approval-decisions",
  "title": "AegisFlow - Approval Decisions",
  "tags": ["aegisflow", "phase-6", "approvals"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Approval Decisions",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_workflow_engine_approval_decisions_total[$__range]))",
          "legendFormat": "decisions"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Approved",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_workflow_engine_approval_decisions_total{decision=\"APPROVED\",status=\"completed\"}[$__range]))",
          "legendFormat": "approved"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rejected",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(aegisflow_workflow_engine_approval_decisions_total{decision=\"REJECTED\",status=\"completed\"}[$__range]))",
          "legendFormat": "rejected"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Approval Decision Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (decision, status) (rate(aegisflow_workflow_engine_approval_decisions_total[$__rate_interval]))",
          "legendFormat": "{{decision}} {{status}}"
        },
        {
          "refId": "B",
          "expr": "sum by (decision, status) (rate(aegisflow_gateway_approval_decision_dispatches_total[$__rate_interval]))",
          "legendFormat": "gateway {{decision}} {{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Approval Decision Latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, decision) (rate(aegisflow_workflow_engine_approval_decision_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "workflow-engine {{decision}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, decision) (rate(aegisflow_gateway_approval_decision_dispatch_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "gateway {{decision}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Approved And Rejected Workflow Transitions",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (new_state, status) (rate(aegisflow_workflow_engine_state_transitions_total{new_state=~\"APPROVED|REJECTED|COMPLETED\"}[$__rate_interval]))",
          "legendFormat": "{{new_state}} {{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "text",
      "title": "Decision Authority Boundary",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "mode": "markdown",
        "content": "Approval dashboard data is operational telemetry only. Authoritative review decisions remain in PostgreSQL approval records, workflow state transitions, workflow timelines, and event outbox records.\n\nPanels intentionally aggregate by decision and status only. They do not label metrics with operator IDs, workflow IDs, approval IDs, borrower values, comments, or document content."
      }
    }
  ]
}
