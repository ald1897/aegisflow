    {
      "name": "Create Mortgage Exception Review Workflow",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Correlation-ID",
            "value": "{{correlationId}}"
          },
          {
            "key": "X-Actor-ID",
            "value": "{{actorId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workflow_type\": \"MORTGAGE_EXCEPTION_REVIEW\",\n  \"priority\": \"HIGH\",\n  \"metadata\": {\n    \"case_reference\": \"MORT-POSTMAN-001\",\n    \"channel\": \"postman\",\n    \"documents\": [\"income_verification\"]\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/workflows",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "workflows"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"workflow created\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.collectionVariables.set(\"workflowId\", json.workflow_id);",
              "pm.collectionVariables.set(\"temporalWorkflowId\", json.temporal_workflow_id || \"\");",
              "pm.collectionVariables.set(\"temporalRunId\", json.temporal_run_id || \"\");",
              "pm.collectionVariables.set(\"workflowPollCount\", \"0\");",
              "",
              "pm.test(\"workflow response has identifiers\", function () {",
              "  pm.expect(json.workflow_id).to.be.a(\"string\").and.not.empty;",
              "  pm.expect(json.correlation_id).to.eql(pm.collectionVariables.get(\"correlationId\"));",
              "  pm.expect(json.temporal_workflow_id).to.be.a(\"string\").and.not.empty;",
              "  pm.expect(json.temporal_run_id).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"workflow starts in NEW state\", function () {",
              "  pm.expect(json.state).to.eql(\"NEW\");",
              "});"
            ]
          }
        }
      ]
    },
