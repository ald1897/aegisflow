              "});",
              "",
              "pm.test(\"tool invocations are governed and validated\", function () {",
              "  const json = pm.response.json();",
              "  json.invocations.forEach((invocation) => {",
              "    pm.expect(invocation.status).to.eql(\"COMPLETED\");",
              "    pm.expect(invocation.permission_status).to.eql(\"AUTHORIZED\");",
              "    pm.expect(invocation.input_validation_status).to.eql(\"VALIDATED\");",
              "    pm.expect(invocation.output_validation_status).to.eql(\"VALIDATED\");",
              "    pm.expect(invocation.output).to.be.an(\"object\");",
              "  });",
              "});"
            ]
          }
        }
      ]
