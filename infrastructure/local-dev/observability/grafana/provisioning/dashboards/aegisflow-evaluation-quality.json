{
  "uid": "aegisflow-evaluation-quality",
  "title": "AegisFlow - Evaluation Quality",
  "tags": ["aegisflow", "phase-7", "evaluation"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Evaluation Runs",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (aegisflow_evaluation_service_evaluation_runs_total)",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Persisted Results",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (score_status) (aegisflow_evaluation_service_evaluation_results_total)",
          "legendFormat": "{{score_status}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Evidence Consistency Signals",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (severity) (aegisflow_evaluation_service_hallucination_signals_total)",
          "legendFormat": "{{severity}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Evaluation Run Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (evaluation_mode, status) (rate(aegisflow_evaluation_service_evaluation_runs_total[$__rate_interval]))",
          "legendFormat": "{{evaluation_mode}} {{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Evaluation Run Duration p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, evaluation_mode, status) (rate(aegisflow_evaluation_service_evaluation_run_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{evaluation_mode}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Results By Evaluator",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (evaluator_id, score_status) (rate(aegisflow_evaluation_service_evaluation_results_total[$__rate_interval]))",
          "legendFormat": "{{evaluator_id}} {{score_status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Prompt-Attributed Results",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (prompt_id, prompt_version, status) (rate(aegisflow_evaluation_service_prompt_regression_results_total[$__rate_interval]))",
          "legendFormat": "{{prompt_id}} {{prompt_version}} {{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "text",
      "title": "Boundary",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "options": {
        "mode": "markdown",
        "content": "Evaluation metrics are aggregate quality telemetry. They do not approve, reject, complete, or mutate workflows. Metric labels intentionally avoid workflow IDs, run IDs, trace IDs, borrower values, prompt content, document content, and approval comments."
      }
    }
  ]
}
