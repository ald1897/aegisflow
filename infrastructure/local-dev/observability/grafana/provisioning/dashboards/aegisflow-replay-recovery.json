      "title": "Stuck Workflow Diagnostics",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (workflow_type, diagnostic_status) (aegisflow_gateway_stuck_workflow_diagnostics_total)",
          "legendFormat": "{{workflow_type}} {{diagnostic_status}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
